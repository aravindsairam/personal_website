# Files/dirs that must NOT be served as part of the public site.
# (Wrangler uploads the whole assets directory otherwise, including .git)
.git/
.gitignore
.assetsignore
.wrangler/
wrangler.jsonc
README.md
node_modules/
docs/
.thumbnail

# Raw media originals (only the compressed web versions are served)
images/DJI_*
images/dummy_10.mp4
images/race.mp4
images/village.mp4
images/lv_0_*
